# Base SQLite (chemin relatif au dossier prisma/ en développement local)
DATABASE_URL="file:./dev.db"

# Auth.js (NextAuth v5)
# Générer AUTH_SECRET avec : openssl rand -base64 32
AUTH_SECRET="remplacer-par-un-secret-aleatoire"
# URL publique de l'application — doit correspondre au domaine affiché dans le navigateur
# En local : http://localhost:3000
# En production : https://iade.baptou.me (exemple)
AUTH_URL="http://localhost:3000"
# Recommandé derrière Cloudflare Tunnel / reverse proxy
AUTH_TRUST_HOST="true"

# Resend (envoi des notifications par e-mail)
# Créer la clé sur https://resend.com/api-keys
RESEND_API_KEY="re_remplacer_par_votre_cle_api"
# Adresse expéditeur (domaine vérifié dans Resend), ex. :
RESEND_FROM="Astreintes IADE <noreply@baptou.me>"

# Cloudflare Tunnel (docker-compose.cloudflare.yml) — token depuis Zero Trust
# CLOUDFLARE_TUNNEL_TOKEN="eyJ..."
