# Base SQLite (chemin relatif au dossier prisma/ en développement local)
DATABASE_URL="file:./dev.db"

# Auth.js (NextAuth v5)
# Générer AUTH_SECRET avec : openssl rand -base64 32
AUTH_SECRET="remplacer-par-un-secret-aleatoire"
# URL publique de l'application
# En local : http://localhost:3000
# En production (Cloudflare Tunnel) : https://astreintes.baptou.me
AUTH_URL="http://localhost:3000"

# SMTP (envoi des notifications par e-mail en production)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="utilisateur-smtp"
SMTP_PASSWORD="mot-de-passe-smtp"
SMTP_FROM="Astreintes IADE <noreply@example.com>"
